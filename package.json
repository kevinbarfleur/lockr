{
  "name": "lockr-cli",
  "version": "1.0.0",
  "description": "Lock and unlock folders with hide mode or AES-256-GCM encryption",
  "type": "module",
  "bin": {
    "lockr": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["cli", "encryption", "folder-lock", "aes-256", "security"],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "ora": "^8.2.0",
    "tar": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
